{
  "name": "@nebelov/yougile-mcp",
  "version": "1.0.5",
  "description": "MCP server for YouGile project management — 57 tools, full API v2 coverage. Works with Claude, ChatGPT, Gemini, Cursor, VS Code.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yougile-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "skill",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "build": "tsc",
    "setup": "node dist/index.js --setup",
