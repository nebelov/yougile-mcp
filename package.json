    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "yougile",
    "project-management",
    "tasks",
    "claude",
    "chatgpt",
    "gemini",
    "ai",
    "model-context-protocol"
  ],
  "author": "nebelov",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nebelov/yougile-mcp"
  },
  "homepage": "https://github.com/nebelov/yougile-mcp#readme",
  "bugs": "https://github.com/nebelov/yougile-mcp/issues",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.9.0",
    "axios": "^1.7.9",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
